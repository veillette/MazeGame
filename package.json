{
  "name": "maze-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "A SceneryStack port of the PhET Maze Game simulation.",
  "license": "MIT",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "biome check .",
    "format": "biome format --write .",
    "fix": "biome check --write .",
    "check": "tsc --noEmit",
    "icons": "tsx scripts/generate-icons.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "scenerystack": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^22.10.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-pwa": "^1.3.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
